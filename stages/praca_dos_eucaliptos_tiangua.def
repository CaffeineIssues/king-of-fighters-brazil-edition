; Stage definition for Praca dos Eucaliptos (Tiangua)
; Build the SFF with:
;   sprmake2.exe stages\praca_dos_eucaliptos_tiangua-sff.def

[Info]
name = "Praca dos Eucaliptos (Tiangua)"
displayname = "Praça dos Eucaliptos (Tianguá)"
versiondate = 06,17,2026
mugenversion = 1.0
author = "Brazilian Meme Fighters Team"

[Camera]
startx = 0
starty = 0
boundleft = -55
boundright = 55
boundhigh = -18
boundlow = 0
verticalfollow = .15
floortension = 0
tension = 50
overdrawhigh = 0
overdrawlow = 0
cuthigh = 0
cutlow = 0
zoomout = 1
zoomin = 1

[PlayerInfo]
p1startx = -70
p1starty = 0
p1facing = 1
p2startx = 70
p2starty = 0
p2facing = -1
leftbound = -1000
rightbound = 1000

[Bound]
screenleft = 15
screenright = 15

[StageInfo]
zoffset = 218
autoturn = 1
resetBG = 1
localcoord = 320, 240
xscale = 1
yscale = 1

[Shadow]
intensity = 80
color = 0,0,0
yscale = .2
fade.range = -300,-100

[Reflection]
intensity = 0

[Music]
bgmusic =
bgmvolume = 100

[BGdef]
spr = praca_dos_eucaliptos_tiangua.sff
debugbg = 0

[BG praca]
type = normal
spriteno = 0,0
start = 0,0
delta = 1,1
mask = 0
layerno = 0
